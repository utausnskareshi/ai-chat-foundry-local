<Window x:Class="AIChatFoundryLocal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AIChatFoundryLocal.Views"
        xmlns:converters="clr-namespace:AIChatFoundryLocal.Converters"
        Title="AI Chat - Foundry Local" Height="750" Width="1100"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid>
        <!-- Initialization overlay -->
        <Grid Visibility="{Binding IsInitialized, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
              Panel.ZIndex="100">
            <Border Background="#1E1E1E">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE99A;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                               Foreground="#0078D4" HorizontalAlignment="Center" Margin="0,0,0,20" />
                    <TextBlock Text="AI Chat - Foundry Local" FontSize="24" FontWeight="SemiBold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10" />
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                 Foreground="#0078D4" Background="#3B3B3B" BorderThickness="0"
                                 Margin="0,10,0,10"
                                 Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVisibility}}" />
                    <TextBlock Text="{Binding InitializationStatus}"
                               Foreground="#999999" FontSize="14"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               MaxWidth="500" TextAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main content -->
        <Grid Visibility="{Binding IsInitialized, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Navigation sidebar -->
            <Border Grid.Column="0" Background="#252526">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- App title -->
                    <Border Grid.Row="0" Padding="16,16,16,12" BorderBrush="#3B3B3B" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="&#xE99A;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                       Foreground="#0078D4" HorizontalAlignment="Center" Margin="0,0,0,8" />
                            <TextBlock Text="AI Chat" FontSize="14" FontWeight="SemiBold"
                                       Foreground="White" HorizontalAlignment="Center" />
                            <TextBlock Text="Foundry Local" FontSize="10"
                                       Foreground="#777777" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Navigation buttons -->
                    <StackPanel Grid.Row="1" Margin="0,8">
                        <RadioButton x:Name="NavChat" GroupName="Nav" IsChecked="True"
                                     Checked="NavChat_Checked" Cursor="Hand">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="border" Background="Transparent" Padding="16,12">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="16" Foreground="#CCCCCC"
                                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                                            <TextBlock Text="チャット" FontSize="14"
                                                       Foreground="#CCCCCC" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#37373D" />
                                            <Setter TargetName="border" Property="BorderBrush" Value="#0078D4" />
                                            <Setter TargetName="border" Property="BorderThickness" Value="3,0,0,0" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#2A2D2E" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                        <RadioButton x:Name="NavModels" GroupName="Nav"
                                     Checked="NavModels_Checked" Cursor="Hand">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="border" Background="Transparent" Padding="16,12">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="16" Foreground="#CCCCCC"
                                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                                            <TextBlock Text="モデル管理" FontSize="14"
                                                       Foreground="#CCCCCC" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#37373D" />
                                            <Setter TargetName="border" Property="BorderBrush" Value="#0078D4" />
                                            <Setter TargetName="border" Property="BorderThickness" Value="3,0,0,0" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#2A2D2E" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                    </StackPanel>

                    <!-- Version info -->
                    <Border Grid.Row="2" Padding="16,8" BorderBrush="#3B3B3B" BorderThickness="0,1,0,0">
                        <TextBlock Text="v1.0.0" FontSize="10" Foreground="#555555"
                                   HorizontalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>

            <!-- Content area -->
            <Grid Grid.Column="1">
                <views:ChatView x:Name="ChatViewControl"
                                DataContext="{Binding ChatViewModel}"
                                Visibility="Visible" />
                <views:ModelManagementView x:Name="ModelManagementViewControl"
                                           DataContext="{Binding ModelManagementViewModel}"
                                           Visibility="Collapsed" />
            </Grid>
        </Grid>
    </Grid>
</Window>
