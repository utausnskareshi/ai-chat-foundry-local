<UserControl x:Class="AIChatFoundryLocal.Views.ModelManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AIChatFoundryLocal.Converters"
             Background="#1E1E1E">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2D2D2D" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                               Foreground="#0078D4" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock Text="モデル管理" FontSize="18" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                            Command="{Binding RefreshModelsCommand}"
                            Background="#3B3B3B" Style="{StaticResource ActionButton}"
                            ToolTip="モデル一覧を更新" Padding="10,6" />
                    <Button Content="モデルをアンロード"
                            Command="{Binding UnloadModelCommand}"
                            Background="#D83B01" Style="{StaticResource ActionButton}"
                            ToolTip="現在ロード中のモデルを解放" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Model list -->
        <ListView Grid.Row="1" ItemsSource="{Binding Models}"
                  SelectedItem="{Binding SelectedModel}"
                  Background="#1E1E1E" Foreground="White"
                  BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  Padding="8">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Margin" Value="4,3" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#2D2D2D" CornerRadius="8" Padding="16,12" Margin="4,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Model name and status -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="{Binding Alias}" Foreground="White"
                                           FontSize="15" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <!-- Cached badge -->
                                <Border Background="#107C10" CornerRadius="3"
                                        Padding="6,2" Margin="8,0,0,0"
                                        Visibility="{Binding IsCached, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="ダウンロード済" Foreground="White" FontSize="10" />
                                </Border>
                                <!-- Loaded badge -->
                                <Border Background="#0078D4" CornerRadius="3"
                                        Padding="6,2" Margin="4,0,0,0"
                                        Visibility="{Binding IsLoaded, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="ロード中" Foreground="White" FontSize="10" />
                                </Border>
                            </StackPanel>

                            <!-- Description -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="{Binding Description}" Foreground="#999999" FontSize="12" />
                                <TextBlock Foreground="#777777" FontSize="12" Margin="12,0,0,0">
                                    <Run Text="デバイス: " />
                                    <Run Text="{Binding DeviceType, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>

                            <!-- Download progress -->
                            <ProgressBar Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                         Value="{Binding DownloadProgress}" Maximum="100"
                                         Height="4" Margin="0,8,0,0"
                                         Foreground="#0078D4" Background="#3B3B3B" BorderThickness="0"
                                         Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}" />

                            <!-- Action buttons -->
                            <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                        Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Download button (show when not cached) -->
                                <Button Content="ダウンロード"
                                        Command="{Binding DataContext.DownloadModelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="#107C10" Style="{StaticResource ActionButton}"
                                        Visibility="{Binding IsCached, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />
                                <!-- Load button (show when cached but not loaded) -->
                                <Button Content="ロード"
                                        Command="{Binding DataContext.LoadModelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="#0078D4" Style="{StaticResource ActionButton}"
                                        Visibility="{Binding IsCached, Converter={StaticResource BoolToVisibility}}" />
                                <!-- Delete button (show when cached) -->
                                <Button Content="削除"
                                        Command="{Binding DataContext.DeleteModelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="#A4262C" Style="{StaticResource ActionButton}"
                                        Visibility="{Binding IsCached, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#252526" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ProgressBar Grid.Column="0" IsIndeterminate="True" Width="80" Height="3"
                             Margin="0,0,10,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                             Foreground="#0078D4" Background="#3B3B3B" BorderThickness="0" />
                <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                           Foreground="#999999" FontSize="12" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
